{
  "name": "quickstack",
  "version": "1.2.1",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --exec node -r @swc-node/register src/index.ts",
    "dev:api": "nodemon --exec node -r @swc-node/register src/index.ts --api",
    "build": "swc src -d dist && tsc-alias -p tsconfig.json",
    "start": "node dist/src/index.js",
    "prepare": "husky",
    "test": "echo \"Error: no test specified\"",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "colors": "^1.4.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@swc-node/register": "^1.11.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.40",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "nodemon": "^3.1.14",
    "prettier": "3.8.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
